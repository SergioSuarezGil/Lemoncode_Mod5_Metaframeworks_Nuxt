{
  "name": "lemoncode-mod5-metaframeworks-nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev:all": "concurrently -n FRONT,API -c cyan,green \"npm run dev\" \"npm run dev:api\"",
    "dev:api": "tsx api-server/src/index.ts",
    "dev": "nuxt dev --host localhost --port 3000 --strict-port",
    "dev:quiet": "NITRO_LOG_LEVEL=0 nuxt dev --host localhost --port 3000 --strict-port",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "nuxt preview",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "postinstall": "nuxt prepare"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@material-tailwind/html": "^3.0.0-beta.7",
    "@nuxt/image": "^2.0.0",
    "hono": "^4.11.0",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  }
}
